# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Football API (optional, MVP uses mock) ===
FOOTBALL_API_PROVIDER=mock
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# === AI Provider (anthropic | openai | gemini | none) ===
# Set to "anthropic" + fill ANTHROPIC_API_KEY to enable Claude-powered analysis
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# === System ===
TIMEZONE=America/Los_Angeles
PRE_MATCH_MINUTES=60
ENABLE_LIVE_SCORE=false
ENABLE_POST_MATCH_REVIEW=false
LOG_LEVEL=info
